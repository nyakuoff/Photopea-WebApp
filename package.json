{
  "name": "photopea-app",
  "version": "1.0.0",
  "description": "A lightweight desktop wrapper for Photopea",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": {
    "name": "nyakuoff",
    "email": "nyakuoff@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.photopea.wrapper",
    "productName": "Photopea",
    "linux": {
      "target": ["AppImage"],
      "category": "Graphics"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
